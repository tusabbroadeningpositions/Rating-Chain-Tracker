rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY SCHEMAS & VALIDATION BLUEPRINTS ---

    function isValidRatingScheme(data) {
      return data.keys().hasAll(['id', 'name', 'userId']) &&
             data.keys().size() <= 15 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.userId is string && data.userId.size() <= 128 &&
             (!data.keys().hasAny(['isShared']) || data.isShared is bool) &&
             (!data.keys().hasAny(['allowEdit']) || data.allowEdit is bool) &&
             (!data.keys().hasAny(['effectiveAsOf']) || data.effectiveAsOf is string && data.effectiveAsOf.size() <= 100) &&
             (!data.keys().hasAny(['proposedEffectiveDateFuture']) || data.proposedEffectiveDateFuture is string && data.proposedEffectiveDateFuture.size() <= 100) &&
             (!data.keys().hasAny(['proposedEffectiveDateAlternate']) || data.proposedEffectiveDateAlternate is string && data.proposedEffectiveDateAlternate.size() <= 100) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp || data.createdAt == null) &&
             (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp || data.updatedAt == null);
    }

    function isValidArmyRatingRecord(data) {
      return data.keys().hasAll(['id', 'schemeId', 'userId', 'element', 'rank', 'name', 'role']) &&
             data.keys().size() <= 30 &&
             data.id is string && data.id.size() <= 128 &&
             data.schemeId is string && data.schemeId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.element is string && data.element.size() <= 300 &&
             data.rank is string && data.rank.size() <= 200 &&
             data.name is string && data.name.size() <= 400 &&
             data.role is string && data.role.size() <= 400 &&
             (!data.keys().hasAny(['dutyMosc']) || data.dutyMosc == null || (data.dutyMosc is string && data.dutyMosc.size() <= 200)) &&
             (!data.keys().hasAny(['from']) || data.from == null || (data.from is string && data.from.size() <= 100)) &&
             (!data.keys().hasAny(['thru']) || data.thru == null || (data.thru is string && data.thru.size() <= 100)) &&
             (!data.keys().hasAny(['dueHqda']) || data.dueHqda == null || (data.dueHqda is string && data.dueHqda.size() <= 100)) &&
             (!data.keys().hasAny(['raterId']) || data.raterId == null || (data.raterId is string && data.raterId.size() <= 128)) &&
             (!data.keys().hasAny(['raterEffectiveDate']) || data.raterEffectiveDate == null || (data.raterEffectiveDate is string && data.raterEffectiveDate.size() <= 100)) &&
             (!data.keys().hasAny(['seniorRaterId']) || data.seniorRaterId == null || (data.seniorRaterId is string && data.seniorRaterId.size() <= 128)) &&
             (!data.keys().hasAny(['seniorRaterEffectiveDate']) || data.seniorRaterEffectiveDate == null || (data.seniorRaterEffectiveDate is string && data.seniorRaterEffectiveDate.size() <= 100)) &&
             (!data.keys().hasAny(['reviewerId']) || data.reviewerId == null || (data.reviewerId is string && data.reviewerId.size() <= 128)) &&
             (!data.keys().hasAny(['reviewerEffectiveDate']) || data.reviewerEffectiveDate == null || (data.reviewerEffectiveDate is string && data.reviewerEffectiveDate.size() <= 100)) &&
             (!data.keys().hasAny(['submissionType']) || data.submissionType == null || (data.submissionType is string && data.submissionType.size() <= 200)) &&
             (!data.keys().hasAny(['version']) || data.version == null || (data.version is string && data.version.size() <= 100)) &&
             (!data.keys().hasAny(['keyLeaderTitle']) || data.keyLeaderTitle == null || (data.keyLeaderTitle is string && data.keyLeaderTitle.size() <= 400)) &&
             (!data.keys().hasAny(['ncoerStatus']) || data.ncoerStatus == null || (data.ncoerStatus is string && data.ncoerStatus.size() <= 200)) &&
             (!data.keys().hasAny(['ncoerStatusDate']) || data.ncoerStatusDate == null || (data.ncoerStatusDate is string && data.ncoerStatusDate.size() <= 100)) &&
             (!data.keys().hasAny(['isCustomStatus']) || data.isCustomStatus is bool) &&
             (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp || data.updatedAt == null);
    }

    // --- MASTER GATE SCHEME AUTHENTICATION ---

    function isSchemeOwner(sId) {
      return exists(/databases/$(database)/documents/schemes/$(sId)) &&
             get(/databases/$(database)/documents/schemes/$(sId)).data.userId == request.auth.uid;
    }

    function isSchemeEditable(sId) {
      return exists(/databases/$(database)/documents/schemes/$(sId)) && (
        get(/databases/$(database)/documents/schemes/$(sId)).data.userId == request.auth.uid || (
          get(/databases/$(database)/documents/schemes/$(sId)).data.isShared == true &&
          get(/databases/$(database)/documents/schemes/$(sId)).data.allowEdit == true
        )
      );
    }

    function isSchemeReadable(sId) {
      return exists(/databases/$(database)/documents/schemes/$(sId)) && (
        get(/databases/$(database)/documents/schemes/$(sId)).data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/schemes/$(sId)).data.isShared == true
      );
    }

    // --- COLLECTION MATCHES ---

    match /schemes/{schemeId} {
      allow get: if isValidId(schemeId) && (
        isOwner(resource.data.userId) || resource.data.isShared == true
      );
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isValidId(schemeId) &&
                    isValidRatingScheme(incoming()) &&
                    isOwner(incoming().userId) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
                    
      allow update: if isValidId(schemeId) &&
                    isValidRatingScheme(incoming()) &&
                    (isOwner(existing().userId) || (existing().isShared == true && existing().allowEdit == true)) && (
                      // Action: Rename
                      (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) && incoming().updatedAt == request.time) ||
                      // Action: Toggle Share
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isShared', 'updatedAt']) && incoming().updatedAt == request.time) ||
                      // Action: Toggle Edit
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['allowEdit', 'updatedAt']) && incoming().updatedAt == request.time) ||
                      // Action: Update Dates
                      (incoming().diff(existing()).affectedKeys().hasOnly(['effectiveAsOf', 'proposedEffectiveDateFuture', 'proposedEffectiveDateAlternate', 'updatedAt']) && incoming().updatedAt == request.time)
                    );
                    
      allow delete: if isValidId(schemeId) && isOwner(resource.data.userId);
    }

    match /records/{recordId} {
      allow get: if isValidId(recordId) && (
        isOwner(resource.data.userId) || isSchemeReadable(resource.data.schemeId)
      );
      
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || 
                     isSchemeReadable(resource.data.schemeId);
      
      allow create: if isValidId(recordId) &&
                    isValidArmyRatingRecord(incoming()) &&
                    isSchemeEditable(incoming().schemeId);
                    
      allow update: if isValidId(recordId) &&
                    isValidArmyRatingRecord(incoming()) &&
                    isSchemeEditable(existing().schemeId) && (
                      // Immutable constraints on id, userId, and schemeId are guaranteed by ensuring they are not part of update-changed fields
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'element', 'dutyMosc', 'rank', 'name', 'from', 'thru', 'dueHqda',
                        'raterId', 'raterEffectiveDate', 'seniorRaterId', 'seniorRaterEffectiveDate',
                        'reviewerId', 'reviewerEffectiveDate', 'submissionType', 'role', 'version', 
                        'keyLeaderTitle', 'ncoerStatus', 'ncoerStatusDate', 'isCustomStatus', 'updatedAt'
                      ]) && (incoming().updatedAt == request.time || incoming().updatedAt == null)
                    );
                    
      allow delete: if isValidId(recordId) && isSchemeEditable(resource.data.schemeId);
    }
  }
}
